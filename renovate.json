{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "UTC",
  "schedule": [
    "before 6am on monday"
  ],
  "prConcurrentLimit": 5,
  "enabledManagers": [
    "docker-compose",
    "terraform",
    "kubernetes",
    "pre-commit",
    "custom.regex"
  ],
  "docker-compose": {
    "managerFilePatterns": [
      "/(^|/)docker-compose\\.ya?ml$/"
    ]
  },
  "terraform": {
    "managerFilePatterns": [
      "/(^|/)terraform/.+\\.tf$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/^oracle-arm/.+\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^oracle-arm/argocd/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "repoURL:\\s*(?<registryUrl>https?://[^\\s]+)\\s*\\n\\s*chart:\\s*(?<depName>[^\\s]+)\\s*\\n\\s*targetRevision:\\s*(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "helm"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "docker-compose",
        "terraform",
        "kubernetes",
        "pre-commit",
        "custom.regex"
      ],
      "groupName": "weekly infra dependencies"
    },
    {
      "matchManagers": [
        "docker-compose",
        "terraform",
        "kubernetes",
        "pre-commit",
        "custom.regex"
      ],
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr",
      "rebaseWhen": "behind-base-branch"
    }
  ]
}
